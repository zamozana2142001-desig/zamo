<!DOCTYPE html>
<html lang="ckb" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>بانگهێشتنامەی هاوسەرگیری زامۆ و سۆما</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Naskh+Arabic:wght@400..700&family=Cairo:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
:root{
  --ink:#7c1732;
  --ink-deep:#4a0e1f;
  --ivory:#fdf3f1;
  --ivory-soft:#f8dfe1;
  --gold:#e08fa2;
  --gold-deep:#c15a72;
  --rose:#c2185b;
  --font-display:'Noto Naskh Arabic', serif;
  --font-body:'Cairo', sans-serif;
}

*{box-sizing:border-box;}

body,html{
  margin:0; padding:0;
  font-family:var(--font-body);
  text-align:center;
  background:var(--ivory);
  color:var(--ink);
  overflow-x:hidden;
}

.hidden{ display:none; }

/* ================= SPLASH ================= */
#splash-screen{
  position:fixed; inset:0;
  background:
    radial-gradient(circle at 50% 35%, rgba(224,143,162,0.22), transparent 55%),
    linear-gradient(160deg, var(--ink-deep), var(--ink) 60%);
  display:flex; align-items:center; justify-content:center;
  z-index:1000;
  overflow:hidden;
}

.leaf{
  position:absolute; top:0; bottom:0; width:50%;
  background:linear-gradient(160deg, var(--ink-deep), var(--ink) 60%);
  transition:transform 1s cubic-bezier(.76,0,.24,1);
  z-index:2;
}
.leaf-right{ right:0; transform-origin:right; }
.leaf-left{ left:0; transform-origin:left; }

#splash-screen.opening .leaf-right{ transform:translateX(100%); }
#splash-screen.opening .leaf-left{ transform:translateX(-100%); }

.splash-inner{
  position:relative; z-index:3;
  color:var(--ivory);
  padding:40px;
  max-width:420px;
  transition:opacity .5s ease .1s, transform .5s ease .1s;
}
#splash-screen.opening .splash-inner{ opacity:0; transform:scale(.92); }

.corner{
  position:absolute; width:34px; height:34px;
  border:1.5px solid var(--gold);
  opacity:.75;
}
.corner-tl{ top:-16px; left:-16px; border-left:none; border-bottom:none; }
.corner-tr{ top:-16px; right:-16px; border-right:none; border-bottom:none; }
.corner-bl{ bottom:-16px; left:-16px; border-left:none; border-top:none; }
.corner-br{ bottom:-16px; right:-16px; border-right:none; border-top:none; }

.eyebrow{
  font-size:13px; letter-spacing:.12em; color:var(--gold);
  margin:0 0 18px;
}

#seal{
  background:none; border:none; cursor:pointer;
  width:132px; height:132px; margin:0 auto 30px;
  position:relative; display:flex; align-items:center; justify-content:center;
  transition:transform .3s ease;
}
#seal:hover{ transform:scale(1.04); }
#seal:focus-visible{ outline:2px solid var(--gold); outline-offset:6px; }

.seal-ring{ position:absolute; inset:0; width:100%; height:100%; }
.ring-outer{ fill:none; stroke:var(--gold); stroke-width:1.4; stroke-dasharray:4 6; }
.ring-inner{ fill:none; stroke:var(--gold); stroke-width:1; opacity:.6; }

.seal-letters{
  font-family:var(--font-display);
  font-size:30px; color:var(--ivory);
  display:flex; align-items:center; gap:6px;
}
.seal-letters .amp{ color:var(--gold); font-size:16px; }

.splash-title{
  font-family:var(--font-display);
  font-size:26px; font-weight:600; margin:0 0 10px;
  line-height:1.5;
}
.splash-hint{ font-size:14px; color:#e9c3ca; margin:0; }

/* ================= CONTENT ================= */
.container{ padding:60px 24px 80px; max-width:600px; margin:auto; }

.monogram{ position:relative; width:88px; height:88px; margin:0 auto 6px; }
.monogram svg{ width:100%; height:100%; }
.monogram circle{ fill:none; stroke:var(--gold); stroke-width:1; opacity:.5; }
.monogram span{
  position:absolute; inset:0; display:flex; align-items:center; justify-content:center;
  font-family:var(--font-display); font-size:22px; color:var(--gold-deep); gap:4px;
}
.monogram .amp-sm{ font-size:12px; color:var(--rose); margin:0 3px; }

header h1{
  font-family:var(--font-display);
  font-size:34px; font-weight:600; margin:6px 0 0;
  color:var(--ink);
}

.rule{
  display:flex; align-items:center; justify-content:center; gap:10px;
  margin:34px auto; max-width:280px;
}
.rule span{ flex:1; height:1px; background:var(--gold); opacity:.6; }
.rule i{ width:6px; height:6px; background:var(--gold); transform:rotate(45deg); flex-shrink:0; }

.names{
  display:flex; align-items:center; justify-content:center; gap:22px;
  margin:0 0 34px;
}
.name-block{ flex:1; }
.role{ font-size:13px; letter-spacing:.1em; color:var(--rose); margin:0 0 6px; }
.highlight{
  font-family:var(--font-display);
  font-size:32px; font-weight:700; margin:0;
  color:var(--ink);
}
.parent{ font-size:14px; color:#8a5b62; margin:8px 0 0; }

.divider svg{ width:26px; height:26px; }
.divider path{ fill:var(--gold); opacity:.8; }

.invite-line{
  font-size:16px; line-height:1.9; color:#6b3d45;
  max-width:440px; margin:0 auto 38px;
}

.date-box{
  background:var(--ivory-soft);
  border:1px solid rgba(198,161,91,.5);
  border-radius:4px;
  padding:26px 20px;
  display:inline-block;
  min-width:260px;
  margin:0 0 50px;
}
.date-main{
  font-family:var(--font-display); font-size:24px; font-weight:600;
  color:var(--ink); margin:0 0 6px; letter-spacing:.03em;
}
.date-sub{ font-size:14px; color:#8a5b62; margin:0; }
.countdown{
  margin-top:14px; padding-top:14px;
  border-top:1px dashed rgba(198,161,91,.6);
  font-size:14px; color:var(--gold-deep); font-weight:600;
}

.section-label{
  font-size:13px; letter-spacing:.12em; color:var(--rose);
  margin:0 0 14px;
}
.map-responsive{
  position:relative; padding-bottom:56.25%; height:0; overflow:hidden;
  border:6px solid var(--ivory-soft);
  outline:1px solid rgba(198,161,91,.5);
  border-radius:6px;
}
.map-responsive iframe{ position:absolute; inset:0; width:100%; height:100%; border:0; }

footer{ margin-top:56px; }
.footer-motif{ width:60px; height:20px; margin:0 auto 14px; display:block; }
.footer-motif path{ fill:none; stroke:var(--gold); stroke-width:1; }
footer p{ font-size:15px; color:#8a5b62; margin:0; }

/* ================= SCROLL REVEAL ================= */
.reveal{
  opacity:0; transform:translateY(18px);
  transition:opacity .7s ease, transform .7s ease;
}
.reveal.in-view{ opacity:1; transform:translateY(0); }

@media (prefers-reduced-motion: reduce){
  .leaf, .splash-inner, .reveal{ transition:none !important; }
  #seal:hover{ transform:none; }
}

@media (max-width:480px){
  .names{ flex-direction:column; gap:26px; }
  .divider{ transform:rotate(90deg); }
  header h1{ font-size:28px; }
  .highlight{ font-size:26px; }
}
</style>
</head>
<body>
  <!-- سپلاش سکرین -->
  <div id="splash-screen">
    <div class="leaf leaf-right"></div>
    <div class="leaf leaf-left"></div>

    <div class="splash-inner">
      <span class="corner corner-tl" aria-hidden="true"></span>
      <span class="corner corner-tr" aria-hidden="true"></span>
      <span class="corner corner-bl" aria-hidden="true"></span>
      <span class="corner corner-br" aria-hidden="true"></span>

      <p class="eyebrow">بانگهێشتنامەیەکی تایبەت</p>

      <button id="seal" onclick="openCard()" aria-label="کردنەوەی بانگهێشتنامە">
        <svg viewBox="0 0 120 120" class="seal-ring" aria-hidden="true">
          <circle cx="60" cy="60" r="56" class="ring-outer"/>
          <circle cx="60" cy="60" r="46" class="ring-inner"/>
        </svg>
        <span class="seal-letters">
          <span>ز</span><span class="amp">و</span><span>س</span>
        </span>
      </button>

      <h1 class="splash-title">بەخێربێن بۆ ئاهەنگی یەکبوونمان</h1>
      <p class="splash-hint">کرتە لەسەر مۆرەکە بکە بۆ کردنەوەی بانگهێشتنامە</p>
    </div>
  </div>

  <!-- ناوەڕۆکی بانگهێشتنامەکە -->
  <div id="invitation-content" class="hidden">
    <div class="container">

      <header class="reveal">
        <div class="monogram" aria-hidden="true">
          <svg viewBox="0 0 120 120">
            <circle cx="60" cy="60" r="54"/>
          </svg>
          <span><span>ز</span><span class="amp-sm">و</span><span>س</span></span>
        </div>
        <p class="eyebrow">بانگهێشتنامەی هاوسەرگیری</p>
        <h1>یەکبوونی دوو دڵ</h1>
      </header>

      <div class="rule reveal" aria-hidden="true"><span></span><i></i><span></span></div>

      <section class="names reveal">
        <div class="name-block">
          <p class="role">زاوا</p>
          <h2 class="highlight">زامۆ</h2>
          <p class="parent">کوڕی بەڕێز زانا</p>
        </div>

        <div class="divider" aria-hidden="true">
          <svg viewBox="0 0 60 60"><path d="M30 4 L36 24 L56 30 L36 36 L30 56 L24 36 L4 30 L24 24 Z"/></svg>
        </div>

        <div class="name-block">
          <p class="role">بووک</p>
          <h2 class="highlight">سۆما</h2>
          <p class="parent">کچی بەڕێز شەفیق</p>
        </div>
      </section>

      <p class="invite-line reveal">بە خۆشحاڵییەوە بانگهێشتی ئێوە دەکەین بۆ بەشداریکردنمان لە دڵخۆشترین ڕۆژی ژیانماندا</p>

      <section class="date-box reveal">
        <div class="date-box-inner">
          <p class="date-main">١٧ - ٧ - ٢٠٢٦</p>
          <p class="date-sub">ڕۆژی هەینی &middot; کاتژمێر ٧:٠٠ی ئێوارە</p>
        </div>
        <div class="countdown" id="countdown" aria-live="polite"></div>
      </section>

      <section class="map reveal">
        <p class="section-label">شوێنی ئاهەنگەکە</p>
        <div class="map-responsive">
    <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d12062.41562102851!2d45.45383137519054!3d35.5389485038096!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x400029dc1536cee7%3A0x7f8a5e717c1bce16!2zUGFya8OuIE1hcmTDrm4g2b7Yp9ix2qnbjCDZhdin2LHYr9uM2YY!5e0!3m2!1sen!2siq!4v1783249255097!5m2!1sen!2siq" width="600" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="strict-origin-when-cross-origin"></iframe>   </section>

      <footer class="reveal">
        <svg class="footer-motif" viewBox="0 0 60 20" aria-hidden="true">
          <path d="M2 10 H24 M36 10 H58" />
          <path d="M30 4 L34 10 L30 16 L26 10 Z" />
        </svg>
        <p>چاوەڕوانی ئامادەبوونی ئێوەین</p>
      </footer>

    </div>
  </div>

  <script>function openCard() {
    const splash = document.getElementById('splash-screen');
    const content = document.getElementById('invitation-content');

    // نیشاندانی ناوەڕۆکەکە پێش داخستنی ئەنیمەیشن، بۆ ئەوەی لەژێر دەروازەکەدا دیار بێت
    content.classList.remove('hidden');

    // ئەنیمەیشنی کردنەوەی دەروازە (دوو لاپەڕەی سپلاشەکە لادەدرێن)
    splash.classList.add('opening');

    // لابردنی سپلاش لە DOM دوای تەواوبوونی ئەنیمەیشنەکە
setTimeout(() => {
        splash.style.display = 'none'; // ئەمە زیاد بکە بۆ ئەوەی ڕێگری لە بینین نەکات
        splash.classList.add('hidden');
        revealSections();
    }, 850);
}

// دیارکردنی بەشەکان بە جوانی کاتێک دەگاتە بەرچاو (scroll reveal)
function revealSections() {
    const items = document.querySelectorAll('.reveal');
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (prefersReduced || !('IntersectionObserver' in window)) {
        items.forEach(el => el.classList.add('in-view'));
        return;
    }

    const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry, i) => {
            if (entry.isIntersecting) {
                setTimeout(() => entry.target.classList.add('in-view'), i * 90);
                observer.unobserve(entry.target);
            }
        });
    }, { threshold: 0.15 });

    items.forEach(el => observer.observe(el));
}

// ژماردنەوەی ڕۆژەکانی ماوە بۆ ئاهەنگەکە
function startCountdown() {
    const countdownEl = document.getElementById('countdown');
    if (!countdownEl) return;

    const weddingDate = new Date('2026-07-17T19:00:00');

    function update() {
        const now = new Date();
        const diffMs = weddingDate - now;

        if (diffMs <= 0) {
            countdownEl.textContent = 'ئاهەنگەکە دەستی پێکردووە!';
            return;
        }

        const days = Math.floor(diffMs / (1000 * 60 * 60 * 24));
        countdownEl.textContent = `${days} ڕۆژ ماوە بۆ ئاهەنگەکە`;
    }

    update();
    setInterval(update, 1000 * 60 * 60);
}

document.addEventListener('DOMContentLoaded', startCountdown);
  </script>
</body>
</html>
